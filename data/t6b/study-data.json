    {
      "id": "t6b-smoke-fume-electrical-fire",
      "title": "Smoke and Fume Elimination / Electrical Fire",
      "category": "Emergency Procedure",
      "steps": [
        "OBOGS - CHECK (BOTH): supply lever ON, concentration lever MAX, pressure lever EMERGENCY",
        "Descend below 10,000 feet MSL - Initiate (as required)",
        "PRESSURIZATION switch - RAM/DUMP",
        "BLEED AIR INFLOW switch - OFF",
        "BAT and GEN switches - OFF",
        "AUX BAT switch - OFF (as required)",
        "CFS handle safety pin - Remove (BOTH)",
        "CFS - Rotate 90 degrees counterclockwise and pull (if necessary)",
        "Restore electrical power - As required",
        "Land as soon as possible"
      ],
      "source": {
        "docId": "a1-t6baa-nfm-000",
        "label": "NATOPS",
        "file": "t6b/A1-T6BAA-NFM-000.pdf",
