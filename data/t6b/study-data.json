    {
      "id": "t6b-emergency-ground-egress",
      "title": "Emergency Ground Egress",
      "category": "Critical Action",
      "steps": [
        "ISS mode selector - SOLO",
        "Seat safety pin - Install (BOTH)",
        "PARKING BRAKE - As required",
        "Canopy - Open",
        "CFS handle safety pin - Remove (BOTH)",
        "CFS handle - Rotate 90 degrees counterclockwise and pull (BOTH)",
        "Upper fittings, lower fittings, and leg restraint garters - Release (BOTH)",
        "BAT, GEN, and AUX BAT switches - OFF",
        "Evacuate aircraft"
      ],
      "source": {
        "docId": "a1-t6baa-nfm-000",
