      }
    },
    {
      "id": "t6b-immediate-airstart-pmu-norm",
      "title": "Immediate Airstart (PMU NORM)",
      "category": "Critical Action",
      "steps": [
        "ZOOM/GLIDE - 125 KNOTS (MINIMUM)",
        "PCL - OFF",
        "PCL - IDLE, ABOVE 13% N1",
        "Engine instruments - Monitor ITT, N1, and oil pressure",
        "PCL - OFF",
        "FIREWALL SHUTOFF handle - Pull",
        "Execute Forced Landing or Eject",
        "PCL - As required after N1 reaches IDLE RPM (approximately 67% N1)",
        "PEL - Execute"
      ],
      "source": {
        "docId": "a1-t6baa-nfm-000",
        "label": "NATOPS",
        "file": "t6b/A1-T6BAA-NFM-000.pdf",
        "page": 288,
        "location": "Immediate Airstart (PMU NORM)"
      }
    },
    {
      "id": "t6b-uncommanded-power-change",
      "title": "Uncommanded Power Changes / Loss of Power / Uncommanded Propeller Feather",
      "category": "Critical Action",
      "steps": [
        "PCL - MID RANGE",
        "PMU SWITCH - OFF",
        "PROP SYS CIRCUIT BREAKER - PULL, IF NP STABLE BELOW 40%",
        "PCL - As required",
        "PEL - Execute",
        "PROP SYS circuit breaker - Reset, as required",
        "PCL - OFF",
        "FIREWALL SHUTOFF handle - Pull",
        "Execute Forced Landing or Eject"
      ],
      "source": {
