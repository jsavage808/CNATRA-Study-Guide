    {
      "id": "t6b-engine-failure-flight",
      "title": "Engine Failure During Flight",
      "category": "Critical Action",
      "steps": [
        "ZOOM/GLIDE - 125 KNOTS (MINIMUM)",
        "PCL - OFF",
        "INTERCEPT ELP",
        "Airstart - Attempt if warranted",
        "FIREWALL SHUTOFF handle - Pull",
        "Execute Forced Landing or Eject"
      ],
      "source": {
