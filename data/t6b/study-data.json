      "id": "t6b-fire-in-flight",
      "title": "Fire In Flight",
      "category": "Critical Action",
      "steps": [
        "PCL - OFF",
        "FIREWALL SHUTOFF HANDLE - PULL",
        "Forced Landing - Execute",
        "Eject (BOTH)",
        "PEL - Execute"
      ],
      "note": "If fire is not confirmed, execute PEL. If fire is extinguished, execute a forced landing.",
